---

---

<!-- Gallery Section -->
<section
  id="gallery"
  class="w-full py-24 md:py-32 px-6 lg:px-12 bg-surface-container border-t-2 border-primary/20 relative"
>
  <div class="reveal mb-16">
    <h2 class="text-4xl font-black uppercase mb-4">THE VIEW FROM THE EDGE</h2>
    <div class="h-1 w-24 bg-primary shadow-[0_0_10px_rgba(139,233,253,0.5)]">
    </div>
  </div>
  <div class="reveal reveal-delay-200 grid grid-cols-1 md:grid-cols-2 gap-4">
    <div
      class="relative group overflow-hidden bg-surface-container h-[250px] md:h-[400px] border border-primary/10 hover:border-primary/40 transition-all"
    >
      <img
        alt="Terminal productivity"
        class="w-full h-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
        data-alt="Dark Tiling Window Manager with Red Accents and Terminal"
        src="/assets/images/xfce4.png"
      />
      <div
        class="absolute inset-0 border-8 border-transparent group-hover:border-primary/20 transition-all pointer-events-none"
      >
      </div>
      <div
        class="absolute bottom-4 left-4 bg-background/90 border border-primary px-4 py-2"
      >
        <span class="text-xs font-bold uppercase tracking-widest text-primary"
          >WORKSPACE_01 / XFCE</span
        >
      </div>
    </div>
    <div
      class="relative group overflow-hidden bg-surface-container h-[250px] md:h-[400px] border border-primary/10 hover:border-primary/40 transition-all"
    >
      <img
        alt="Cyber security terminal"
        class="w-full h-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
        data-alt="Cyberpunk Matrix Style Code Scrolling in Red"
        src="/assets/images/gnome.png"
      />
      <div
        class="absolute inset-0 border-8 border-transparent group-hover:border-primary/20 transition-all pointer-events-none"
      >
      </div>
      <div
        class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
      >
        <a
          href="/gallery"
          class="inline-flex items-center gap-4 border-2 border-primary px-8 py-4 font-headline uppercase tracking-[0.2em] font-bold text-primary hover:bg-primary hover:text-background transition-colors group w-fit"
        >
          VIEW FULL GALLERY
        </a>
      </div>
    </div>
    <div
      class="relative group overflow-hidden bg-surface-container h-[200px] md:h-[300px] md:col-span-2 border border-primary/10"
    >
      <img
        alt="Server room lighting"
        class="w-full h-full object-cover grayscale opacity-30 group-hover:grayscale-0 group-hover:opacity-70 transition-all duration-300"
        data-alt="Abstract Dark Data Center with Red Neon Lights"
        src="/assets/images/berserkarch.png"
      />
      <div class="absolute inset-0 flex items-center justify-center">
        <div
          class="text-center p-8 bg-background/90 backdrop-blur-md border border-primary shadow-[0_0_30px_rgba(139,233,253,0.15)]"
        >
          <h4
            class="text-xl font-bold uppercase tracking-tighter mb-2 text-primary"
          >
            BerserkArch
          </h4>
          <p class="text-xs text-on-surface-variant tracking-widest font-bold">
            STABILITY WITH BLEEDING EDGE
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
