---
const screenshots = [
  {
    src: "/images/xfce4.png",
    alt: "BerserkArch XFCE4 Desktop",
    label: "WORKSPACE_01 / XFCE",
  },
  {
    src: "/images/gnome.png",
    alt: "BerserkArch GNOME Desktop",
    label: "WORKSPACE_02 / GNOME",
  },
  {
    src: "/images/kde.png",
    alt: "BerserkArch KDE Plasma Desktop",
    label: "WORKSPACE_03 / KDE",
  },
  {
    src: "/images/openbox.png",
    alt: "BerserkArch Openbox Desktop",
    label: "WORKSPACE_04 / OPENBOX",
  },
  {
    src: "/images/hyprland.png",
    alt: "BerserkArch Hyprland Desktop",
    label: "WORKSPACE_05 / HYPRLAND",
  },
  {
    src: "/images/i3wm.png",
    alt: "BerserkArch I3WM Desktop",
    label: "WORKSPACE_06 / I3WM",
  },
];
---

<!-- Gallery Section -->
<section
  id="gallery"
  class="w-full py-24 md:py-32 px-6 lg:px-12 bg-surface-container border-t-2 border-primary/20 relative"
>
  <div class="reveal mb-16">
    <h2 class="text-4xl font-black uppercase mb-4">THE VIEW FROM THE EDGE</h2>
    <div class="h-1 w-24 bg-primary shadow-[0_0_10px_rgba(139,233,253,0.5)]">
    </div>
  </div>
  <div
    class="reveal reveal-delay-200 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
  >
    {
      screenshots.map((shot, i) => (
        <div class="relative group overflow-hidden bg-surface-container border border-primary/10 hover:border-primary/40 transition-all h-[250px] md:h-[300px]">
          <img
            alt={shot.alt}
            class="w-full h-full object-cover opacity-50 group-hover:opacity-100 transition-all duration-300"
            style="filter: brightness(0.4) saturate(0.6);"
            onmouseenter="this.style.filter='none'"
            onmouseleave="this.style.filter='brightness(0.4) saturate(0.6)'"
            src={shot.src}
            loading={i < 3 ? "eager" : "lazy"}
          />
          <div class="absolute inset-0 border-8 border-transparent group-hover:border-primary/20 transition-all pointer-events-none"></div>
          <div class="absolute bottom-4 left-4 bg-background/90 border border-primary px-4 py-2">
            <span class="text-xs font-bold uppercase tracking-widest text-primary">
              {shot.label}
            </span>
          </div>
        </div>
      ))
    }
  </div>
  <div class="mt-8 flex justify-center">
    <a
      href="/gallery"
      class="inline-flex items-center gap-4 border-2 border-primary px-8 py-4 font-headline uppercase tracking-[0.2em] font-bold text-primary hover:bg-primary hover:text-background transition-colors"
    >
      VIEW FULL GALLERY
    </a>
  </div>
</section>
