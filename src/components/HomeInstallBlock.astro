---
import InstallStep from './InstallStep.astro';
---
<!-- Installation Section -->
<section class="py-24 px-8 md:px-24 bg-surface">
<div class="flex flex-col md:flex-row gap-16">
<div class="reveal md:w-1/3">
<h2 class="text-4xl font-black uppercase mb-6 flex items-center gap-3">
<span class="h-8 w-2 bg-primary"></span>
                    INSTALLATION
                </h2>
<p class="text-on-surface-variant mb-8 leading-relaxed">
                    The ritual of installation is the first step of the struggle. Follow the sequence precisely. No graphical installers. No hand-holding.
                </p>
<div class="space-y-4">
<InstallStep number="01" title="DOWNLOAD THE ISO" active={true} />
<InstallStep number="02" title="START THE INSTALLER" />
<InstallStep number="03" title="DONE." />
</div>
</div>
<div class="reveal reveal-delay-200 md:w-2/3 bg-surface-container-lowest border border-primary/30 relative">
<div class="bg-surface-container-high px-4 py-2 flex items-center justify-between border-b border-primary/20">
<div class="flex gap-2">
<div class="w-3 h-3 bg-primary"></div>
<div class="w-3 h-3 bg-primary/40"></div>
<div class="w-3 h-3 bg-primary/20"></div>
</div>
<span class="text-[10px] uppercase tracking-widest text-primary font-bold">terminal — root@berserkarch</span>
</div>
<div class="p-8 font-mono text-sm leading-relaxed overflow-x-auto whitespace-pre text-on-surface-variant">
<span class="text-primary font-bold">guts@berserkarch</span> ~ $ <span class="text-on-surface">btweak --help</span>                   
usage: btweak [-h] [-v] &#123;fix,tools,docker&#125; ...

Berserk Arch Tweak Tool

positional arguments:
  &#123;fix,tools,docker&#125;
    fix               Fix things in berserkarch
    tools             List, install and remove tools
    docker            List and manage docker images for systems and tools

options:
  -h, --help          show this help message and exit
  -v, --version       show program's version number and exit
<span class="text-primary font-bold">guts@berserkarch</span> ~ $ <span class="animate-pulse text-primary font-bold">_</span>
</div>
</div>
</div>
</section>
