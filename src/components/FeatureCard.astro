---
const { icon, modNumber, title, description } = Astro.props;
---
<div class="feature-card group">
    <div class="mb-6 flex justify-between items-start">
        <span class="material-symbols-outlined text-primary text-4xl drop-shadow-[0_0_8px_rgba(139,233,253,0.4)]" data-icon={icon}>{icon}</span>
        <span class="text-primary font-mono text-xs font-bold">{modNumber}</span>
    </div>
    <h3 class="text-2xl font-bold uppercase mb-4 text-on-background">{title}</h3>
    <p class="text-on-surface-variant font-body leading-relaxed">
        {description}
    </p>
</div>
