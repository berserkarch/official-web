---
import { Image } from "astro:assets";
import logo from "../assets/images/logo.svg";
---

<!-- Hero Section -->
<section
  class="min-h-[70vh] md:min-h-[921px] py-16 md:py-0 flex flex-col justify-center px-8 md:px-24 border-b border-primary/20 relative overflow-hidden"
>
  <div
    class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10 pointer-events-none"
  >
  </div>
  <div
    class="max-w-7xl w-full relative z-10 flex items-center justify-between gap-12"
  >
    <div class="max-w-4xl">
      <div class="flex items-center gap-4 mb-6">
        <div class="h-12 w-1 bg-primary"></div>
        <span
          class="text-primary font-bold tracking-widest uppercase text-xs md:text-sm drop-shadow-[0_0_8px_rgba(139,233,253,0.3)]"
          >FOR HACKERS BY HACKERS</span
        >
      </div>
      <h1
        class="reveal text-6xl md:text-9xl font-black tracking-[-0.05em] text-on-background uppercase mb-4 leading-none"
      >
        BERSERK <span
          class="text-primary drop-shadow-[0_0_15px_rgba(139,233,253,0.4)]"
          >ARCH</span
        >
      </h1>
      <p
        class="reveal reveal-delay-100 text-xl md:text-4xl font-light text-on-surface-variant tracking-tight mb-6 max-w-3xl"
      >
        A distro crafted for hackers, developers, and nerds alike.
      </p>
      <div id="version-badge" class="reveal reveal-delay-150 mb-8 flex flex-wrap items-center gap-x-3 gap-y-1 opacity-0 transition-opacity duration-500">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-primary/10 border border-primary/30 font-mono text-xs text-primary tracking-widest uppercase shrink-0">
          <span class="material-symbols-outlined" style="font-size:13px; font-variation-settings: 'FILL' 1;">new_releases</span>
          LATEST
        </span>
        <span id="version-string" class="font-mono text-xs md:text-sm text-on-surface-variant/80 tracking-wide break-all"></span>
      </div>
      <div class="reveal reveal-delay-200 flex flex-wrap gap-4 z-20">
        <div class="relative group inline-block">
          <button
            class="btn-primary flex items-center justify-center gap-2 outline-none cursor-pointer"
          >
            GET THE ISO
            <span
              class="material-symbols-outlined text-sm leading-none"
              style="font-variation-settings: 'FILL' 1;">arrow_drop_down</span
            >
          </button>
          <div
            class="absolute left-0 mt-0 w-full bg-background border-2 border-primary z-50 shadow-[0_0_20px_rgba(139,233,253,0.15)] opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto group-focus-within:opacity-100 group-focus-within:translate-y-0 group-focus-within:pointer-events-auto transition-all duration-300 ease-out"
          >
            <a
              class="block px-6 py-4 text-primary font-mono text-[11px] font-bold uppercase tracking-widest hover:bg-primary hover:text-background transition-colors duration-200 border-b border-primary/30 outline-none"
              href="/download">DIRECT_ISO</a
            >
            <a
              class="block px-6 py-4 text-primary font-mono text-[11px] font-bold uppercase tracking-widest hover:bg-primary hover:text-background transition-colors duration-200 border-b border-primary/30 outline-none"
              href="https://sourceforge.net/projects/berserkarch/files/"
              >SOURCE_FORGE</a
            >
            <a
              class="block px-6 py-4 text-primary font-mono text-[11px] font-bold uppercase tracking-widest hover:bg-primary hover:text-background transition-colors duration-200 border-b border-primary/30 outline-none"
              href="https://drive.google.com/drive/folders/14sOpnU4iMUeivxWvj9rvctVFgGUbXiAq"
              data-track="gdrive"
              >GOOGLE_DRIVE</a
            >
            <a
              class="block px-6 py-4 text-primary font-mono text-[11px] font-bold uppercase tracking-widest hover:bg-primary hover:text-background transition-colors duration-200 outline-none"
              href="/torrent">TORRENT</a
            >
          </div>
        </div>
        <a
          href="https://wiki.berserkarch.org"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline flex items-center justify-center"
        >
          READ THE MAN
        </a>
      </div>
      <p class="reveal reveal-delay-300 mt-4 text-xs font-mono text-on-surface-variant/50 tracking-widest uppercase flex items-center gap-2 pointer-events-none select-none">
        <span class="material-symbols-outlined text-xs leading-none" style="font-size:14px;">download</span>
        <span id="dl-count" class="inline-block min-w-[5ch] transition-opacity duration-500">—</span>
        <span>total downloads</span>
      </p>

      <script>
        // --- Latest release version ---
        (async () => {
          const badge = document.getElementById("version-badge");
          const vspan = document.getElementById("version-string");
          if (!badge || !vspan) return;
          try {
            const res = await fetch("https://iso.berserkarch.org/latest.txt");
            if (!res.ok) return;
            const raw = (await res.text()).trim();
            const text = raw.split("/").pop()?.replace(/\.iso$/i, "") ?? "";
            if (text) {
              vspan.textContent = text;
              badge.style.opacity = "1";
            }
          } catch {
            // leave hidden
          }
        })();

        // --- Download counter display ---
        (async () => {
          const el = document.getElementById("dl-count");
          if (!el) return;
          try {
            const res = await fetch("/api/downloads");
            if (!res.ok) return;
            const { total } = await res.json();
            if (total > 0) {
              el.style.opacity = "0";
              setTimeout(() => {
                el.textContent = total.toLocaleString("en-US");
                el.style.opacity = "1";
              }, 150);
            }
          } catch {
            // leave the dash fallback
          }
        })();

        // --- Click tracking for Google Drive + Torrent links ---
        document.querySelectorAll("[data-track]").forEach((link) => {
          link.addEventListener("click", () => {
            const source = (link as HTMLElement).dataset.track;
            navigator.sendBeacon(
              "/api/downloads",
              new Blob([JSON.stringify({ source })], { type: "application/json" })
            );
          });
        });
      </script>
    </div>
  </div>
  <div class="hidden lg:block absolute -bottom-5 right-12 opacity-9">
    <Image src={logo} alt="Berserk Arch Logo" width={560} height={560} />
  </div>
</section>
