---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <div class="crt-overlay"></div>
    <main class="relative min-h-screen flex items-center justify-center pt-16 pb-12 overflow-hidden cursor-crosshair">
        <!-- Background Ghost Text -->
        <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none p-12">
            <div class="ghost-text font-black text-[20vw] leading-none uppercase tracking-tighter">BERSERK</div>
            <div class="ghost-text font-black text-[15vw] leading-none uppercase tracking-tighter -mt-10">ARCH_VOID</div>
        </div>
        
        <!-- Terminal Center Box -->
        <div class="relative z-10 w-full max-w-4xl px-4">
            <div class="bg-background border-2 border-primary p-1">
                <!-- Inner Layout with Border and Corners -->
                <div class="border border-primary/30 p-8 md:p-12 relative">
                    <!-- Corner Brackets (Crosshair Detail) -->
                    <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-primary"></div>
                    <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-primary"></div>
                    <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-primary"></div>
                    <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-primary"></div>
                    
                    <div class="flex flex-col items-center text-center gap-6">
                        <div class="reveal space-y-2">
                            <h1 class="text-8xl md:text-[12rem] font-black tracking-tighter text-primary glitch-text leading-none">404</h1>
                            <div class="bg-primary text-background px-4 py-1 inline-block font-mono text-xs font-bold tracking-[0.3em]">
                                CRITICAL_ERROR: RESOURCE_NOT_FOUND
                            </div>
                        </div>
                        
                        <!-- Terminal Output Block -->
                        <div class="reveal reveal-delay-100 w-full bg-surface-container-lowest border border-primary/20 p-6 font-mono text-left text-[10px] md:text-xs leading-relaxed overflow-hidden relative">
                            <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none" style="background: repeating-linear-gradient(0deg, transparent, transparent 1px, #8BE9FD 1px, #8BE9FD 2px); background-size: 100% 4px;"></div>
                            <div class="flex flex-col gap-1 text-primary/80">
                                <p class="text-primary font-bold">&gt; INITIATING_RECOVERY_PROTOCOL_SUBROUTINE...</p>
                                <p>&gt; [FETCH] GET /SYSTEM/ARCHIVES/INDEX.DB ... FAILED (404)</p>
                                <p>&gt; [MEM_DUMP] 0x0045F2A: 42 45 52 53 45 52 4b 5f 41 52 43 48 5f 4e 55 4c 4c</p>
                                <p>&gt; [MEM_DUMP] 0x0045F3A: 00 00 FF 71 6C FF FF FF 00 00 00 00 1A 19 19 0E</p>
                                <p>&gt; [SYSLOG] WARNING: Pointer at 0xDEADBEEF resolved to void space.</p>
                                <p class="text-destructive">&gt; FATAL: SEGMENTATION_FAULT IN MODULE 'REALITY_PARSER'</p>
                                <p>&gt; [TRACE] Node_01 &gt; Node_02 &gt; [X] NULL_POINTER</p>
                                <p class="mt-2 text-primary animate-pulse">_</p>
                            </div>
                        </div>
                        
                        <!-- Actions -->
                        <div class="reveal reveal-delay-200 flex flex-col md:flex-row gap-4 w-full justify-center mt-4">
                            <a href="/" class="btn-primary flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">terminal</span>
                                &gt; RETURN_BASE
                            </a>
                            <a href="#" class="btn-outline flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">report</span>
                                &gt; REPORT_ANOMALY
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Decorative Info -->
        <div class="absolute bottom-16 right-8 hidden lg:block border-l-2 border-primary/30 pl-4 py-2 z-10">
            <div class="text-primary/50 font-mono text-[10px] uppercase tracking-tighter">
                SESS_ID: BRSK_9921_0XF<br/>
                LOC: SECTOR_NULL<br/>
                TIME: 00:00:00.000000
            </div>
        </div>
    </main>
</Layout>

<style>
.crt-overlay {
    position: fixed;
    top: 0; left: 0; bottom: 0; right: 0;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
    z-index: 100;
    background-size: 100% 2px, 3px 100%;
    pointer-events: none;
}
.glitch-text {
    text-shadow: 2px 0 var(--color-error), -2px 0 var(--color-primary);
}
.ghost-text {
    color: rgba(255, 255, 255, 0.02);
    user-select: none;
}
</style>
