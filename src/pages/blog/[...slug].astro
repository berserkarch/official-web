---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const blogEntries = await getCollection('blog');
    return blogEntries.map(entry => ({
        params: { slug: entry.id }, props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`BERSERK_ARCH // ${entry.id.toUpperCase()}`}>
    <main class="pt-32 pb-20 px-6 max-w-5xl mx-auto relative reveal">
        <!-- Back Action -->
        <div class="mb-12">
            <a class="font-mono text-primary font-bold hover:text-on-primary-fixed hover:bg-primary px-4 py-2 inline-block transition-colors duration-150 text-sm tracking-widest border border-primary hover:border-transparent" href="/blog">
                &gt; RETURN_TO_LOGS
            </a>
        </div>
        
        <!-- Article Header -->
        <article class="space-y-8">
            <header class="border-l-4 border-primary pl-6 py-4 bg-surface-container-low reveal reveal-delay-100">
                <div class="flex flex-wrap gap-6 mb-4 font-mono text-[10px] tracking-[0.2em]">
                    <span class="text-on-surface-variant">DATE: <span class="text-on-surface">{entry.data.pubDate.toISOString().split('T')[0]}</span></span>
                    <span class="text-on-surface-variant">STATUS: <span class="text-primary">VERIFIED</span></span>
                    <span class="text-on-surface-variant">AUTHOR: <span class="text-on-surface">{entry.data.author}</span></span>
                    <span class="text-on-surface-variant">NODE: <span class="text-on-surface">127.0.0.1</span></span>
                </div>
                <h1 class="text-4xl md:text-6xl font-black font-headline uppercase tracking-tighter text-on-surface leading-none">
                    {entry.data.title}
                </h1>
            </header>
            
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-12 pt-8">
                <!-- Main Content (MDX Render) -->
                <div class="lg:col-span-3 space-y-8 mdx-content reveal reveal-delay-200">
                    <Content />
                </div>
                
                <!-- Sidebar Metadata -->
                <aside class="space-y-8 reveal reveal-delay-300">
                    <div class="p-6 bg-surface-container uppercase tracking-widest font-mono text-[10px] space-y-4">
                        <div class="border-b border-outline-variant pb-2">
                            <span class="text-on-surface-variant block">Build_Hash</span>
                            <span class="text-primary break-all">8F32-X091-B77C-4421-E001</span>
                        </div>
                        <div class="border-b border-outline-variant pb-2">
                            <span class="text-on-surface-variant block">Dependencies</span>
                            <span class="text-on-surface">GCC 13.2.1<br/>MDX 3.0.0</span>
                        </div>
                        <div class="border-b border-outline-variant pb-2">
                            <span class="text-on-surface-variant block">System_Load</span>
                            <span class="text-on-surface">LOW</span>
                        </div>
                    </div>
                    
                    <div class="p-6 border-2 border-outline-variant space-y-4">
                        <h4 class="font-headline font-bold uppercase tracking-tight text-sm">Tags</h4>
                        <nav class="space-y-3 font-mono text-xs">
                            {entry.data.tags?.map(tag => (
                                <a class="block text-on-surface-variant hover:text-primary" href={`/blog/tags/${tag}`}>&gt; {tag}</a>
                            )) || <span class="text-on-surface-variant opacity-50">NO_TAGS_FOUND</span>}
                        </nav>
                    </div>
                </aside>
            </div>
        </article>
    </main>
</Layout>
